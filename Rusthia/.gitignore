# Generated by Cargo
# will have compiled files and executables
debug/
target/

# Remove Cargo.lock from gitignore if creating an executable, leave it for libraries
# More information here https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html
# Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which can now be removed
# (if you compile on Windows)
*.pdb

# ----------------------------------------------------------------------
# Rusthia / Rhythia Specific
# ----------------------------------------------------------------------

# Fichier de sauvegarde locale (scores, combos, precision)
save.json

# Ne pas inclure les maps des utilisateurs dans le dépôt,
# Sauf si on place une map par défaut, on peut garder le dossier vide avec un .gitkeep (optionnel)
/maps/*
!/maps/.gitkeep
!/maps/default_map.sspm

# Fichiers OS
.DS_Store
Thumbs.db
